{
  "name": "nextjs-template",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "sh -c 'set -a; . ./.env.development; set +a; NEXT_PUBLIC_APP_ENV=development next dev -p 3000'",
    "dev:local": "NEXT_PUBLIC_APP_ENV=local next dev -p 5000",
    "build": "sh -c 'set -a; . ./.env.production; set +a; NEXT_PUBLIC_APP_ENV=production next build'",
    "build:dev": "sh -c 'set -a; . ./.env.development; set +a; NEXT_PUBLIC_APP_ENV=development next build'",
    "start": "sh -c 'set -a; . ./.env.production; set +a; NEXT_PUBLIC_APP_ENV=production next start -p 3000'",
    "start:dev": "sh -c 'set -a; . ./.env.development; set +a; NEXT_PUBLIC_APP_ENV=development next start -p 3000'",
    "i18n:import": "node scripts/import-locale.mjs",
    "lint": "eslint"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1051.0",
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-query-devtools": "^5.100.10",
    "ag-grid-community": "^35.3.0",
    "ag-grid-react": "^35.3.0",
    "clsx": "^2.1.1",
    "echarts": "^6.0.0",
    "exceljs": "^4.4.0",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.75.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}

# =============================================
# 이 파일을 복사해서 .env.local 로 사용하세요
# .env.local 은 절대 git에 커밋하지 마세요!
# =============================================

# ── 내부 백엔드 API ──────────────────────────
# 서버 컴포넌트 / API Route에서 사용 (브라우저에 노출 X)
API_BASE_URL=http://localhost:8080/api

# ── 외부 공개 API (브라우저에서도 접근 가능) ──
# NEXT_PUBLIC_ prefix가 붙어야 클라이언트에서 접근 가능
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api

# true: src/mocks 데이터 사용, false: NEXT_PUBLIC_API_BASE_URL 실제 API 호출
NEXT_PUBLIC_USE_MOCK_API=true

# ── 외부 서드파티 API ────────────────────────
NEXT_PUBLIC_KAKAO_MAP_KEY=your_kakao_map_key_here
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
SOME_SECRET_API_KEY=secret_key_not_exposed_to_browser

# ── 앱 설정 ─────────────────────────────────
NEXT_PUBLIC_APP_NAME=My App

# local/development: 모든 메뉴와 페이지 접근 허용
# production/staging: 아래 feature 목록에 등록된 기능만 노출 및 접근 허용
NEXT_PUBLIC_APP_ENV=local

# 서버 접근 제어 기준입니다. 브라우저에 노출되지 않습니다.
APP_ENABLED_FEATURES=dashboard,mypage,notices,inquiries,qna

# 클라이언트 메뉴 노출 기준입니다. APP_ENABLED_FEATURES와 같은 값으로 맞추세요.
NEXT_PUBLIC_ENABLED_FEATURES=dashboard,mypage,notices,inquiries,qna

# 사용 가능 키:
# dashboard,mypage,user-permissions,login-history,organizations,data-codes,
# notices,inquiries,qna,storybook,error-preview

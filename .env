# =============================================
# 공통 기본값
# 모든 환경에서 공유 가능한 안전한 기본값만 작성합니다.
# 환경별 API 주소와 외부 키는 .env.local, .env.development, .env.production에서 관리합니다.
# =============================================

# ── 앱 설정 ─────────────────────────────────
NEXT_PUBLIC_APP_NAME="My App"

# ── API 기본값 ──────────────────────────────
# 서버 전용 API URL입니다. 브라우저에 노출되지 않습니다.
API_BASE_URL=http://localhost:8080/api

# 브라우저에서 접근 가능한 API URL입니다.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api

# ── Mock API ────────────────────────────────
# true: src/mocks 데이터 사용, false: 실제 API 호출
NEXT_PUBLIC_USE_MOCK_API=true
